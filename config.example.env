# doc-generate-skill 配置模板。
# 运行 ./setup.sh 会引导你填写并生成 config.local.env(被 .gitignore 忽略,不会上传)。
# 所有密钥/私有 token 只存在 config.local.env,本模板不含任何真实值。

# ── 飞书知识库落点(必填)──────────────────────────────
# 文档归档到飞书 wiki。需要:一个 wiki 空间 + 两个父节点(分享类 / 日常类)。
FEISHU_WIKI_SPACE=          # wiki 空间 id,如 7310305802064003073
FEISHU_PARENT_SHARE=        # 「分享/学习类」父节点 token(如「AI 助手知识库」)
FEISHU_ROOT_AUTO=           # 「日常自动生成」根节点 token(下挂 月/日 目录)

# ── HTML 在线发布(可选;不配则 --html 不可用)──────────
# 默认 scp 到一台 SSH 服务器拿可访问链接;也可改成真正的 S3(见 scripts/upload-html.sh)。
UPLOAD_SSH_KEY=             # 本机 SSH 私钥绝对路径(放 ~/.ssh/ 下,chmod 600)
UPLOAD_USER_DIR=            # 服务器上的个人子目录名(英文短名)
UPLOAD_SERVER=             # 形如 root@1.2.3.4
UPLOAD_BASE_DIR=/var/www/htmls
UPLOAD_BASE_URL=           # 形如 http://1.2.3.4

# ── 发飞书消息(可选)──────────────────────────────────
# --notify 时把文档链接推到这个 webhook(如本地 sidecar 的 /notify)。留空则跳过。
NOTIFY_URL=
